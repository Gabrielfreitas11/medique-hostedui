# =============================================================================
# medique-hostedui — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# For production, also fill the PRODUCTION section and see
# docs/deployment.md for the full deploy procedure.
#
# NEVER commit .env with real values. It is gitignored.
# =============================================================================


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ OpenAI API                                                               │
# └───────────────────────────────────────────────────────────────────────────┘

# REQUIRED. Your OpenAI API key. Starts with "sk-".
# Create a DEDICATED key for this project at https://platform.openai.com/api-keys
# Do not reuse a personal key — isolation limits blast radius if compromised.
OPENAI_API_KEY=sk-change-me

# API endpoint. Change only if using a proxy or OpenAI-compatible provider.
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Enable OpenAI API connections in Open WebUI. Must be true.
ENABLE_OPENAI_API=true

# Disable Ollama API. We use OpenAI exclusively.
# Setting this to false hides the Ollama connection panel in Admin settings
# and prevents confusion about which provider is active.
ENABLE_OLLAMA_API=false

# Model pre-selected for new chats. Students see this by default.
# Available after OpenAI connection is verified (see docs/deployment.md).
DEFAULT_MODELS=gpt-4o-mini


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ Security                                                                 │
# └───────────────────────────────────────────────────────────────────────────┘

# Authentication — must be true. Unauthenticated access is never allowed.
WEBUI_AUTH=true

# JWT signing secret. Used to sign session tokens.
#   Development:  any string works (the default below is fine).
#   Production:   MUST be a strong random value.
#                 Generate with:  openssl rand -hex 32
#                 Changing this invalidates all active sessions (users must re-login).
WEBUI_SECRET_KEY=dev-only-change-in-prod

# Self-registration.
#   First launch:  set to true, create your admin account, then set to false.
#   After setup:   must be false. Admin creates student accounts manually.
ENABLE_SIGNUP=true


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ RAG (Retrieval-Augmented Generation)                                     │
# └───────────────────────────────────────────────────────────────────────────┘

# MUST remain false — the bot must not search the web. Non-negotiable.
ENABLE_RAG_WEB_SEARCH=false

# MUST remain false — prevents Open WebUI from generating web search queries.
ENABLE_SEARCH_QUERY=false

# Embedding provider. Must match the LLM provider for consistency.
RAG_EMBEDDING_ENGINE=openai

# Embedding model. Used for both document indexing and query embedding.
# text-embedding-3-small: good quality, low cost ($0.02/1M tokens).
# text-embedding-3-large: better quality, higher cost ($0.13/1M tokens).
# IMPORTANT: Changing this after PDFs are uploaded requires re-uploading all PDFs
# (the old embeddings become incompatible with the new model).
RAG_EMBEDDING_MODEL=text-embedding-3-small


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ UI / Branding                                                            │
# └───────────────────────────────────────────────────────────────────────────┘

# Custom name shown in the UI header and browser tab.
WEBUI_NAME=Medique - Tutor Educacional

# Local port for the dev UI (not used in production — Nginx handles routing).
WEBUI_PORT=3000


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION — Uncomment and fill when deploying to a server               │
# └───────────────────────────────────────────────────────────────────────────┘

# --- Security (REQUIRED for production) ---
# WEBUI_SECRET_KEY=<paste output of: openssl rand -hex 32>
# ENABLE_SIGNUP=false

# --- PostgreSQL (REQUIRED for production) ---
# POSTGRES_USER=medique
# POSTGRES_PASSWORD=<paste output of: openssl rand -hex 16>
# POSTGRES_DB=medique

# --- Domain (reference only; Nginx reads cert files directly) ---
# DOMAIN=yourdomain.com
